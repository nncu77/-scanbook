# Copy to .env.local and fill in real values. .env.local is gitignored.
# Anything prefixed NEXT_PUBLIC_ is exposed to the browser bundle — do NOT put secrets there.

# --- Anthropic (server-side only) ---
# Direct: leave ANTHROPIC_BASE_URL empty, use sk-ant-* key.
# Via OpenRouter: ANTHROPIC_BASE_URL=https://openrouter.ai/api, use sk-or-v1-* key,
#                 and set models below to anthropic/claude-sonnet-4.6 + anthropic/claude-haiku-4.5
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# Override the default model IDs if you want to pin a snapshot, downgrade for cost,
# or use OpenRouter (which prefixes with anthropic/ and uses dot instead of dash).
# Defaults in code: SCANBOOK_PRIMARY_MODEL=claude-sonnet-4-6, SCANBOOK_ROUTER_MODEL=claude-haiku-4-5-20251001
SCANBOOK_PRIMARY_MODEL=
SCANBOOK_ROUTER_MODEL=

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key bypasses RLS. Server-side only, NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Public site URL (for sitemap.xml and robots.txt) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Demo mode ---
# Must match public.demo_user_id() in the migration.
NEXT_PUBLIC_DEMO_USER_ID=00000000-0000-0000-0000-0000000d3000
# Anti-abuse: daily upload cap per authenticated user on /api/receipts POST.
# In-memory counter resets on server restart. Set higher for prod (e.g. 500).
DAILY_UPLOAD_LIMIT=200

# Lifetime upload cap per account (DB-counted, persistent). Prevents one
# account from filling Storage / draining Claude credits. Set to a higher
# number for trusted users or unset to use the code default (30).
LIFETIME_UPLOAD_LIMIT=30
